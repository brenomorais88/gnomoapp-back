    {
      "name": "Occurrences",
      "item": [
        {
          "name": "List Occurrences",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (Array.isArray(body) && body.length > 0 && body[0].id) {",
                  "    pm.environment.set('occurrenceId', body[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/occurrences?status=PENDING&categoryId={{categoryId}}&text=internet&startDate=2026-04-01&endDate=2026-04-30&month={{month}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "occurrences"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "PENDING"
                },
                {
                  "key": "categoryId",
                  "value": "{{categoryId}}"
                },
                {
                  "key": "text",
                  "value": "internet"
                },
                {
